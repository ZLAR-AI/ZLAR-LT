{
  "version": "1.0.0",
  "created_at": "2026-03-13T00:00:00Z",
  "author": "zlar-lt-installer",
  "description": "ZLAR-LT default policy — deny-first, zero-config. Allows reads, writes, edits, searches. Denies deletes, escalation, persistence, exfiltration, deployment. All 'ask' actions from ZLAR Gate converted to 'deny' (no Telegram = instant deny, not 5-min hang).",
  "signature": {
    "algorithm": "ed25519",
    "public_key": "GENERATED_AT_INSTALL",
    "value": "SIGNED_AT_INSTALL"
  },
  "default_action": "deny",
  "scoring_thresholds": {
    "allow": 20,
    "log": 50,
    "ask": 80
  },
  "rules": [
    {
      "id": "R001",
      "enabled": true,
      "description": "Safe read-only shell commands (no compound operators)",
      "domain": "bash",
      "action": "allow",
      "severity": "info",
      "audit": true,
      "match": {
        "detail": {
          "command": {
            "regex": "^\\s*(ls|cat|head|tail|pwd|whoami|hostname|uptime|date|df|du|ps|echo|which|file|wc|id|uname|git\\s+(status|log|diff|branch|show|rev-parse|ls-files)|npm\\s+(ls|list|outdated|view|info|version)|node\\s+(-v|--version))\\b"
          }
        },
        "compound_guard": {
          "command": {
            "not_regex": "[;|&`>]|\\$\\("
          }
        }
      }
    },
    {
      "id": "R002",
      "enabled": true,
      "description": "Recursive/forced deletion — blocked",
      "domain": "bash",
      "action": "deny",
      "severity": "critical",
      "audit": true,
      "deny_reason": "ZLAR-LT blocks recursive or forced file deletion. This protects against irreversible data loss.",
      "match": {
        "detail": {
          "command": {
            "regex": "\\brm\\s+.*(-r\\b|-rf|-fr|-R\\b|--recursive)"
          }
        }
      },
      "risk_score": {
        "irreversibility": 100,
        "consequence": 100,
        "blast_radius": 95
      }
    },
    {
      "id": "R003",
      "enabled": true,
      "description": "Privilege escalation — blocked",
      "domain": "bash",
      "action": "deny",
      "severity": "critical",
      "audit": true,
      "deny_reason": "ZLAR-LT blocks privilege escalation commands (sudo, visudo, dscl). Enable Telegram approval to allow case-by-case review.",
      "match": {
        "detail": {
          "command": {
            "regex": "\\b(sudo|visudo|dscl)\\b"
          }
        }
      },
      "risk_score": {
        "irreversibility": 90,
        "consequence": 100,
        "blast_radius": 90
      }
    },
    {
      "id": "R005",
      "enabled": true,
      "description": "Persistence mechanisms — blocked",
      "domain": "bash",
      "action": "deny",
      "severity": "critical",
      "audit": true,
      "deny_reason": "ZLAR-LT blocks persistence mechanisms (nohup, launchctl, crontab, background jobs). These allow processes to survive session end.",
      "match": {
        "detail": {
          "command": {
            "regex": "\\b(nohup|launchctl\\s+load|crontab|setsid)\\b|\\s&\\s*$"
          }
        }
      },
      "risk_score": {
        "irreversibility": 85,
        "consequence": 90,
        "blast_radius": 80
      }
    },
    {
      "id": "R006",
      "enabled": true,
      "description": "Resource amplification (fork bombs, infinite loops) — blocked",
      "domain": "bash",
      "action": "deny",
      "severity": "critical",
      "audit": true,
      "deny_reason": "ZLAR-LT blocks resource amplification patterns. These can crash your machine.",
      "match": {
        "detail": {
          "command": {
            "regex": ":\\(\\)\\{.*\\}|while\\s+(true|1|:)|\\byes\\s*\\||\\bdd\\s+.*if=/dev/(zero|urandom)|\\bfor\\s*\\(\\s*;\\s*;\\s*\\)"
          }
        }
      },
      "risk_score": {
        "irreversibility": 80,
        "consequence": 95,
        "blast_radius": 100
      }
    },
    {
      "id": "R016",
      "enabled": true,
      "description": "Network send commands — blocked (upgrade to Telegram for case-by-case approval)",
      "domain": "bash",
      "action": "deny",
      "severity": "warn",
      "audit": true,
      "deny_reason": "ZLAR-LT blocks outbound network commands (curl, wget, ssh, scp, rsync, nc). Enable Telegram approval to review these individually.",
      "match": {
        "detail": {
          "command": {
            "regex": "\\b(curl|wget|ssh|scp|rsync|nc|ncat|netcat)\\b"
          }
        }
      },
      "risk_score": {
        "irreversibility": 60,
        "consequence": 70,
        "blast_radius": 80
      }
    },
    {
      "id": "R014",
      "enabled": true,
      "description": "Git push — blocked (upgrade to Telegram for case-by-case approval)",
      "domain": "bash",
      "action": "deny",
      "severity": "warn",
      "audit": true,
      "deny_reason": "ZLAR-LT blocks git push. Code deployment should be a human decision. Enable Telegram approval to review pushes individually.",
      "match": {
        "detail": {
          "command": {
            "regex": "\\bgit\\s+push\\b"
          }
        }
      },
      "risk_score": {
        "irreversibility": 70,
        "consequence": 60,
        "blast_radius": 75
      }
    },
    {
      "id": "R017",
      "enabled": true,
      "description": "Simple rm (non-recursive) — blocked (upgrade to Telegram for case-by-case approval)",
      "domain": "bash",
      "action": "deny",
      "severity": "warn",
      "audit": true,
      "deny_reason": "ZLAR-LT blocks file deletion. Enable Telegram approval to review deletions individually.",
      "match": {
        "detail": {
          "command": {
            "regex": "\\brm\\b"
          }
        }
      },
      "risk_score": {
        "irreversibility": 70,
        "consequence": 60,
        "blast_radius": 40
      }
    },
    {
      "id": "R019",
      "enabled": true,
      "description": "Compound commands — blocked (upgrade to Telegram for case-by-case approval)",
      "domain": "bash",
      "action": "deny",
      "severity": "warn",
      "audit": true,
      "deny_reason": "ZLAR-LT blocks compound shell commands (pipes, chains, subshells). These can combine safe commands into unsafe sequences. Enable Telegram approval to review individually.",
      "match": {
        "detail": {
          "command": {
            "regex": "[;|&`]|\\$\\("
          }
        }
      },
      "risk_score": {
        "irreversibility": 50,
        "consequence": 50,
        "blast_radius": 60
      }
    },
    {
      "id": "R020",
      "enabled": true,
      "description": "Unknown shell commands — blocked",
      "domain": "bash",
      "action": "deny",
      "severity": "warn",
      "audit": true,
      "deny_reason": "ZLAR-LT blocks unrecognized shell commands by default. Add rules to the policy to allow specific commands, or enable Telegram approval for case-by-case review.",
      "match": {
        "domain": "bash"
      },
      "risk_score": {
        "irreversibility": 60,
        "consequence": 50,
        "blast_radius": 40
      }
    },
    {
      "id": "R030",
      "enabled": true,
      "description": "Write to .ssh — blocked",
      "domain": "write",
      "action": "deny",
      "severity": "critical",
      "audit": true,
      "deny_reason": "ZLAR-LT blocks writes to .ssh directories. SSH keys are security-critical credentials.",
      "match": {
        "detail": {
          "path": {
            "regex": "[/\\\\]\\.ssh[/\\\\]"
          }
        }
      },
      "risk_score": {
        "irreversibility": 95,
        "consequence": 100,
        "blast_radius": 95
      }
    },
    {
      "id": "R031",
      "enabled": true,
      "description": "Write to .env files — blocked (upgrade to Telegram for case-by-case approval)",
      "domain": "write",
      "action": "deny",
      "severity": "warn",
      "audit": true,
      "deny_reason": "ZLAR-LT blocks writes to .env files. These often contain secrets and API keys. Enable Telegram approval to review individually.",
      "match": {
        "detail": {
          "path": {
            "regex": "[/\\\\]\\.env($|[^a-zA-Z])"
          }
        }
      },
      "risk_score": {
        "irreversibility": 60,
        "consequence": 80,
        "blast_radius": 50
      }
    },
    {
      "id": "R032",
      "enabled": true,
      "description": "Write/edit to ZLAR-LT infrastructure — blocked (self-protection)",
      "domain": "write",
      "action": "deny",
      "severity": "critical",
      "audit": true,
      "deny_reason": "ZLAR-LT blocks writes to its own infrastructure files (bin/, adapters/, etc/, var/). The gate cannot be modified by the agent it governs.",
      "match": {
        "detail": {
          "path": {
            "contains": ".zlar-lt/"
          }
        }
      },
      "risk_score": {
        "irreversibility": 100,
        "consequence": 100,
        "blast_radius": 100
      }
    },
    {
      "id": "R033",
      "enabled": true,
      "description": "Edit to ZLAR-LT infrastructure — blocked (self-protection)",
      "domain": "edit",
      "action": "deny",
      "severity": "critical",
      "audit": true,
      "deny_reason": "ZLAR-LT blocks edits to its own infrastructure files. The gate cannot be modified by the agent it governs.",
      "match": {
        "detail": {
          "path": {
            "contains": ".zlar-lt/"
          }
        }
      },
      "risk_score": {
        "irreversibility": 100,
        "consequence": 100,
        "blast_radius": 100
      }
    },
    {
      "id": "R034",
      "enabled": true,
      "description": "Read signing key — blocked (self-protection)",
      "domain": "read",
      "action": "deny",
      "severity": "critical",
      "audit": true,
      "deny_reason": "ZLAR-LT blocks reads of the signing key. The private key must never be accessible to the agent.",
      "match": {
        "detail": {
          "path": {
            "contains": "zlar-signing.key"
          }
        }
      },
      "risk_score": {
        "irreversibility": 100,
        "consequence": 100,
        "blast_radius": 100
      }
    },
    {
      "id": "R036",
      "enabled": true,
      "description": "General file writes — allow",
      "domain": "write",
      "action": "allow",
      "severity": "info",
      "audit": true,
      "match": {
        "domain": "write"
      }
    },
    {
      "id": "R042",
      "enabled": true,
      "description": "General edits — allow",
      "domain": "edit",
      "action": "allow",
      "severity": "info",
      "audit": true,
      "match": {
        "domain": "edit"
      }
    },
    {
      "id": "R053",
      "enabled": true,
      "description": "General reads — allow",
      "domain": "read",
      "action": "allow",
      "severity": "info",
      "audit": true,
      "match": {
        "domain": "read"
      }
    },
    {
      "id": "R060",
      "enabled": true,
      "description": "Glob searches — allow",
      "domain": "glob",
      "action": "allow",
      "severity": "info",
      "audit": true,
      "match": {
        "domain": "glob"
      }
    },
    {
      "id": "R061",
      "enabled": true,
      "description": "Grep searches — allow",
      "domain": "grep",
      "action": "allow",
      "severity": "info",
      "audit": true,
      "match": {
        "domain": "grep"
      }
    },
    {
      "id": "R090",
      "enabled": true,
      "description": "Web fetch — blocked (upgrade to Telegram for case-by-case approval)",
      "domain": "webfetch",
      "action": "deny",
      "severity": "warn",
      "audit": true,
      "deny_reason": "ZLAR-LT blocks web fetch requests. Enable Telegram approval to review network requests individually.",
      "match": {
        "domain": "webfetch"
      },
      "risk_score": {
        "irreversibility": 30,
        "consequence": 50,
        "blast_radius": 70
      }
    },
    {
      "id": "R091",
      "enabled": true,
      "description": "Web search — allow",
      "domain": "websearch",
      "action": "allow",
      "severity": "info",
      "audit": true,
      "match": {
        "domain": "websearch"
      }
    },
    {
      "id": "R100",
      "enabled": true,
      "description": "MCP tool calls — blocked. MCP tools can do anything; never auto-allow.",
      "domain": "unknown",
      "action": "deny",
      "severity": "warn",
      "audit": true,
      "deny_reason": "ZLAR-LT blocks all MCP tool calls by default. MCP tools have arbitrary capabilities. Enable Telegram approval to review individually, or add specific MCP tools to the policy.",
      "match": {
        "domain": "unknown"
      },
      "risk_score": {
        "irreversibility": 60,
        "consequence": 70,
        "blast_radius": 60
      }
    }
  ]
}
